<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             id="Definitions_1"
             targetNamespace="http://bpmn.io/schema/bpmn">
  <category id="Category_1">
    <categoryValue id="CategoryValue_1" value="Group 1" />
  </category>
  <category id="Category_2">
    <categoryValue id="CategoryValue_2" value="Preserved" />
  </category>
  <process id="Process_1" isExecutable="false">
    <task id="Task_A" categoryValueRef="CategoryValue_1">
      <outgoing>SequenceFlow_1</outgoing>
    </task>
    <task id="Task_B">
      <incoming>SequenceFlow_1</incoming>
    </task>
    <sequenceFlow id="SequenceFlow_1"
                  sourceRef="Task_A"
                  targetRef="Task_B"
                  categoryValueRef="CategoryValue_1" />
    <group id="Group_1" categoryValueRef="CategoryValue_1" />
    <group id="Group_PRESERVED" categoryValueRef="CategoryValue_2" />
    <group id="Group_NO_CATEGORY_VALUE" />
  </process>
  <process id="Process_2" isExecutable="false">
    <task id="Task_NOT_RENDERED" categoryValueRef="CategoryValue_2" />
  </process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_1">
      <bpmndi:BPMNShape id="Task_A_di" bpmnElement="Task_A">
        <dc:Bounds x="150" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_B_di" bpmnElement="Task_B">
        <dc:Bounds x="300" y="150" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="SequenceFlow_1_di" bpmnElement="SequenceFlow_1">
        <di:waypoint x="250" y="190" />
        <di:waypoint x="300" y="190" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Group_1_di" bpmnElement="Group_1">
        <dc:Bounds x="100" y="100" width="350" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Group_NO_CATEGORY_VALUE_di" bpmnElement="Group_NO_CATEGORY_VALUE">
        <dc:Bounds x="100" y="100" width="350" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Group_PRESERVED_di" bpmnElement="Group_PRESERVED">
        <dc:Bounds x="500" y="100" width="150" height="125" />
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>
