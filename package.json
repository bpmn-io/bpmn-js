{
  "name": "bpmn-js",
  "version": "18.18.0",
  "description": "A bpmn 2.0 toolkit and web modeler",
  "type": "module",
  "main": "lib/index.js",
  "exports": {
    ".": "./lib/index.js",
    "./lib/core": "./lib/core/index.js",
    "./lib/draw": "./lib/draw/index.js",
    "./lib/features/align-elements": "./lib/features/align-elements/index.js",
    "./lib/features/append-preview": "./lib/features/append-preview/index.js",
    "./lib/features/auto-place": "./lib/features/auto-place/index.js",
    "./lib/features/auto-resize": "./lib/features/auto-resize/index.js",
    "./lib/features/context-pad": "./lib/features/context-pad/index.js",
    "./lib/features/copy-paste": "./lib/features/copy-paste/index.js",
    "./lib/features/di-ordering": "./lib/features/di-ordering/index.js",
    "./lib/features/distribute-elements": "./lib/features/distribute-elements/index.js",
    "./lib/features/drilldown": "./lib/features/drilldown/index.js",
    "./lib/features/editor-actions": "./lib/features/editor-actions/index.js",
    "./lib/features/grid-snapping": "./lib/features/grid-snapping/index.js",
    "./lib/features/grid-snapping/behavior": "./lib/features/grid-snapping/behavior/index.js",
    "./lib/features/interaction-events": "./lib/features/interaction-events/index.js",
    "./lib/features/keyboard": "./lib/features/keyboard/index.js",
    "./lib/features/label-editing": "./lib/features/label-editing/index.js",
    "./lib/features/label-link": "./lib/features/label-link/index.js",
    "./lib/features/modeling": "./lib/features/modeling/index.js",
    "./lib/features/modeling/behavior": "./lib/features/modeling/behavior/index.js",
    "./lib/features/modeling-feedback": "./lib/features/modeling-feedback/index.js",
    "./lib/features/ordering": "./lib/features/ordering/index.js",
    "./lib/features/outline": "./lib/features/outline/index.js",
    "./lib/features/palette": "./lib/features/palette/index.js",
    "./lib/features/popup-menu": "./lib/features/popup-menu/index.js",
    "./lib/features/replace": "./lib/features/replace/index.js",
    "./lib/features/replace-preview": "./lib/features/replace-preview/index.js",
    "./lib/features/rules": "./lib/features/rules/index.js",
    "./lib/features/search": "./lib/features/search/index.js",
    "./lib/features/snapping": "./lib/features/snapping/index.js",
    "./lib/features/space-tool": "./lib/features/space-tool/index.js",
    "./lib/import": "./lib/import/index.js",
    "./lib/*": "./lib/*",
    "./test/helper": "./test/helper/index.js",
    "./test/*": "./test/*"
  },
  "files": [
    "dist",
    "lib",
    "test/util",
    "test/helper",
    "test/matchers",
    "!.eslintrc",
    "!lib/**/*.spec.ts"
  ],
  "scripts": {
    "all": "run-s lint test generate-types distro test:distro",
    "lint": "eslint .",
    "format": "run-s format:markdown 'lint -- --fix'",
    "format:markdown": "remark . -qo",
    "start": "cross-env SINGLE_START=modeler npm run dev",
    "start:viewer": "cross-env SINGLE_START=viewer npm run dev",
    "start:navigated-viewer": "cross-env SINGLE_START=navigated-viewer npm run dev",
    "dev": "npm test -- --auto-watch --no-single-run",
    "test": "karma start test/config/karma.unit.cjs",
    "distro": "node tasks/build-distro.js",
    "collect-translations": "cross-env COLLECT_TRANSLATIONS=1 npm test",
    "generate-types": "run-s generate-types:*",
    "generate-types:generate": "del-cli \"lib/**/*.d.ts\" \"lib/**/*.d.ts.map\" && npx bio-dts -r lib --declarationMap",
    "generate-types:test": "tsc --noEmit --noImplicitAny",
    "test:distro": "node tasks/test-distro.js",
    "postversion": "run-s distro test:distro",
    "prepare": "run-s distro",
    "prepublishOnly": "run-s generate-types"
  },
  "engines": {
    "node": "*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bpmn-io/bpmn-js"
  },
  "keywords": [
    "bpmn",
    "bpmn-js",
    "toolkit",
    "web modeler",
    "modeler",
    "modeling",
    "process modeling"
  ],
  "author": {
    "name": "Nico Rehwaldt",
    "url": "https://github.com/nikku"
  },
  "contributors": [
    {
      "name": "bpmn.io contributors",
      "url": "https://github.com/bpmn-io"
    }
  ],
  "license": "SEE LICENSE IN LICENSE",
  "sideEffects": [
    "*.css"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@bpmn-io/a11y": "^0.1.0",
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "babel-loader": "^10.1.1",
    "babel-plugin-istanbul": "^8.0.0",
    "bio-dts": "^0.15.2",
    "bpmn-font": "^0.12.1",
    "camunda-bpmn-moddle": "^4.0.1",
    "chai": "^6.2.2",
    "chai-match": "^1.1.1",
    "cpy": "^13.2.1",
    "cross-env": "^10.1.0",
    "del": "^8.0.0",
    "del-cli": "^7.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-bpmn-io": "^2.3.1",
    "execa": "^9.0.0",
    "file-drops": "^0.7.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher-2": "^3.3.0",
    "karma-coverage": "^2.2.0",
    "karma-debug-launcher": "^0.0.5",
    "karma-env-preprocessor": "^0.1.1",
    "karma-firefox-launcher": "^2.1.3",
    "karma-mocha": "^2.0.1",
    "karma-safari-launcher": "^1.0.0",
    "karma-webpack": "^5.0.1",
    "mocha": "^11.0.0",
    "mocha-test-container-support": "0.2.0",
    "npm-run-all2": "^9.0.1",
    "puppeteer": "^25.1.0",
    "remark-cli": "^12.0.1",
    "remark-preset-bpmn-io": "^0.4.0",
    "rollup": "^4.61.1",
    "rollup-plugin-license": "^3.7.1",
    "sinon": "^22.0.0",
    "sinon-chai": "^4.0.0",
    "ts-expect": "^1.3.0",
    "typescript": "^5.9.3",
    "webpack": "^5.107.2"
  },
  "dependencies": {
    "bpmn-moddle": "^10.0.0",
    "diagram-js": "^15.17.0",
    "diagram-js-direct-editing": "^3.4.0",
    "ids": "^3.0.2",
    "inherits-browser": "^0.1.0",
    "min-dash": "^5.0.0",
    "min-dom": "^5.3.0",
    "tiny-svg": "^4.1.4"
  },
  "remarkConfig": {
    "plugins": [
      "preset-bpmn-io",
      [
        "lint-no-html",
        false
      ]
    ]
  }
}
